# Supabase (create project at https://supabase.com)
NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Admin page at /admin – set a strong password
ADMIN_PASSWORD=your-secure-password

# Stripe Secret Key (for creating checkout sessions — Stripe Dashboard > Developers > API keys)
STRIPE_SECRET_KEY=sk_live_...

# Registry: Stripe Payment Link for cash gifts (fallback if checkout API unavailable)
NEXT_PUBLIC_STRIPE_REGISTRY_URL=https://buy.stripe.com/...

# Registry: Stripe Payment Link with Alipay enabled (for Chinese guests)
NEXT_PUBLIC_ALIPAY_REGISTRY_URL=https://buy.stripe.com/...

# Registry: Venmo link (direct profile URL, no fees)
NEXT_PUBLIC_VENMO_URL=https://venmo.com/u/YourHandle

# Optional: link to external gift registry (e.g. Amazon, Crate and Barrel)
# NEXT_PUBLIC_GIFT_REGISTRY_URL=https://...

# SendGrid (email service — get API key at https://sendgrid.com)
SENDGRID_API_KEY=SG.xxxxx
SENDGRID_FROM=Your Name <you@gmail.com>

# Site URL (used in email links and cover image)
NEXT_PUBLIC_SITE_URL=https://your-wedding.vercel.app

# Guest password (shared password to access the site)
NEXT_PUBLIC_GUEST_PASSWORD=your-guest-password

# Stripe Webhook Secret (Stripe Dashboard > Developers > Webhooks > Signing secret)
STRIPE_WEBHOOK_SECRET=whsec_...

# Cron secret (auto-set by Vercel for cron jobs; set any value for local testing)
CRON_SECRET=your-cron-secret
